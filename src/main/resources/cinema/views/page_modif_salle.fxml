<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="400.0" prefWidth="640.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cinema.controllers.ModifierSalleController">
    <children>
        <MenuBar VBox.vgrow="NEVER">
            <menus>
                <Menu mnemonicParsing="false" text="Navigation">
                    <items>
                        <MenuItem fx:id="bAccueil" mnemonicParsing="false" onAction="#bAccueilClick" text="Retour à l'accueil" />
                        <MenuItem fx:id="bListeSalle" mnemonicParsing="false" onAction="#bListeSalleClick" text="Liste des salles" />
                    </items>
                </Menu>
            </menus>
        </MenuBar>
        <AnchorPane VBox.vgrow="ALWAYS">
            <children>
                <Label layoutX="179.0" layoutY="41.0" text="Modifier la Salle" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>

                <VBox layoutX="179.0" layoutY="100.0" spacing="15.0">
                    <children>
                        <Label text="Numéro / Nom de la salle :" />
                        <TextField fx:id="tfNumSalle" prefWidth="300.0" />

                        <Label text="Capacité :" />
                        <TextField fx:id="tfCapacite" prefWidth="300.0" />

                        <Label text="Cinéma rattaché :" />
                        <ComboBox fx:id="cbCinema" prefWidth="300.0" />
                    </children>
                </VBox>

                <Button fx:id="bEnregistrer" layoutX="179.0" layoutY="310.0" mnemonicParsing="false" onAction="#bEnregistrerClick" prefHeight="35.0" prefWidth="110.0" style="-fx-background-color: #f39c12;" text="Mettre à jour" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>

                <Button fx:id="bRetour" layoutX="369.0" layoutY="310.0" mnemonicParsing="false" onAction="#bRetourClick" prefHeight="35.0" prefWidth="110.0" style="-fx-background-color: #c0392b;" text="Annuler" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
            </children>
        </AnchorPane>
    </children>
</VBox>